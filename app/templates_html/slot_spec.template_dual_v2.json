{
  "template_id": "template_dual_v2",
  "template_contract_version": "poster2.template_dual_v2.v1",
  "canvas": { "w": 1024, "h": 1024 },
  "safe_margin": 48,
  "layers": {
    "background": { "x": 0, "y": 0, "w": 1024, "h": 1024 },
    "background_base_layer": { "x": 0, "y": 0, "w": 1024, "h": 1024 },
    "background_tone_layer": { "x": 0, "y": 0, "w": 1024, "h": 1024 },
    "header_banner": { "x": 72, "y": 56, "w": 880, "h": 104 },
    "header_shell_layer": { "x": 72, "y": 56, "w": 880, "h": 104 },
    "brand_logo_layer": { "x": 104, "y": 74, "w": 120, "h": 64 },
    "brand_text_layer": { "x": 244, "y": 72, "w": 432, "h": 68 },
    "agent_pill_layer": { "x": 756, "y": 78, "w": 156, "h": 48 },
    "scenario": { "x": 96, "y": 188, "w": 288, "h": 520 },
    "scenario_card_layer": { "x": 96, "y": 188, "w": 288, "h": 520 },
    "scenario_card_shell_layer": { "x": 96, "y": 188, "w": 288, "h": 520 },
    "scenario_image_layer": { "x": 96, "y": 188, "w": 288, "h": 520 },
    "product": { "x": 456, "y": 188, "w": 300, "h": 520 },
    "product_card_shell_layer": { "x": 456, "y": 188, "w": 300, "h": 520 },
    "product_image_layer": { "x": 456, "y": 188, "w": 300, "h": 520 },
    "feature_callouts": { "x": 764, "y": 204, "w": 164, "h": 392 },
    "feature_callout_layer": { "x": 764, "y": 204, "w": 164, "h": 392 },
    "text_zone": { "x": 112, "y": 728, "w": 800, "h": 144 },
    "title_layer": { "x": 112, "y": 744, "w": 800, "h": 84 },
    "subtitle_layer": { "x": 152, "y": 840, "w": 720, "h": 28 },
    "bottom_gallery": { "x": 96, "y": 888, "w": 832, "h": 72 },
    "bottom_gallery_shell_layer": { "x": 96, "y": 888, "w": 832, "h": 72 },
    "bottom_gallery_items_layer": { "x": 96, "y": 904, "w": 832, "h": 56 },
    "bottom_tagline_layer": { "x": 196, "y": 966, "w": 632, "h": 20 }
  },
  "layer_slots": {
    "brand_logo_slot": { "x": 104, "y": 74, "w": 120, "h": 64 },
    "brand_name_slot": { "x": 244, "y": 72, "w": 432, "h": 68 },
    "agent_pill_slot": { "x": 756, "y": 78, "w": 156, "h": 48 },
    "scenario_card_slot": { "x": 96, "y": 188, "w": 288, "h": 520 },
    "bottom_gallery_strip": { "x": 96, "y": 888, "w": 832, "h": 72 }
  },
  "regions": {
    "background_region": { "x": 0, "y": 0, "w": 1024, "h": 1024 },
    "header_region": { "x": 72, "y": 56, "w": 880, "h": 104 },
    "scenario_region": { "x": 96, "y": 188, "w": 288, "h": 520 },
    "product_region": { "x": 456, "y": 188, "w": 300, "h": 520 },
    "feature_region": { "x": 764, "y": 204, "w": 164, "h": 392 },
    "bottom_region": { "x": 96, "y": 728, "w": 832, "h": 258 }
  },
  "layer_states": {
    "header_banner": ["state-logo-show", "state-logo-empty"],
    "scenario": ["state-show", "state-safe-fill"],
    "bottom_gallery": ["state-show", "state-fallback-fill", "state-hidden"]
  },
  "layer_contracts": {
    "background_base_layer": {
      "visible_when": "always",
      "bounds": { "x": 0, "y": 0, "w": 1024, "h": 1024 },
      "fallback_rule": "use resolved background layer only; never substitute for scenario_image_layer",
      "collapse_rule": "never collapse"
    },
    "background_tone_layer": {
      "visible_when": "disabled unless explicit tone overlay is bound",
      "bounds": { "x": 0, "y": 0, "w": 1024, "h": 1024 },
      "fallback_rule": "skip tone overlay when no explicit tone binding exists",
      "collapse_rule": "collapse fully when tone overlay is unbound"
    },
    "header_shell_layer": {
      "visible_when": "always",
      "bounds": { "x": 72, "y": 56, "w": 880, "h": 104 },
      "padding": { "top": 18, "right": 24, "bottom": 18, "left": 24 },
      "max_items": 3,
      "max_lines": 0,
      "fallback_rule": "render banner shell even when logo/text collapse",
      "collapse_rule": "never collapse"
    },
    "brand_logo_layer": {
      "visible_when": "logo.url exists",
      "bounds": { "x": 104, "y": 74, "w": 120, "h": 64 },
      "padding": { "top": 0, "right": 0, "bottom": 0, "left": 0 },
      "max_items": 1,
      "max_lines": 0,
      "fallback_rule": "hide logo only; do not make logo visibility depend on brand_text_layer",
      "collapse_rule": "collapse only this layer when logo is absent"
    },
    "brand_text_layer": {
      "visible_when": "brand_name present",
      "bounds": { "x": 244, "y": 72, "w": 432, "h": 68 },
      "padding": { "top": 10, "right": 16, "bottom": 10, "left": 0 },
      "max_items": 1,
      "max_lines": 1,
      "fallback_rule": "expand width when brand_logo_layer collapses",
      "collapse_rule": "do not depend on logo visibility"
    },
    "agent_pill_layer": {
      "visible_when": "agent_name present",
      "bounds": { "x": 756, "y": 78, "w": 156, "h": 48 },
      "padding": { "top": 0, "right": 12, "bottom": 0, "left": 12 },
      "max_items": 1,
      "max_lines": 1,
      "fallback_rule": "auto-shrink text inside pill",
      "collapse_rule": "collapse when agent_name is empty"
    },
    "scenario_card_shell_layer": {
      "visible_when": "always",
      "bounds": { "x": 96, "y": 188, "w": 288, "h": 520 },
      "padding": { "top": 0, "right": 0, "bottom": 0, "left": 0 },
      "max_items": 1,
      "max_lines": 0,
      "fallback_rule": "keep card shell visible for safe preset backdrop",
      "collapse_rule": "never collapse"
    },
    "scenario_image_layer": {
      "visible_when": "scenario_image.url exists or safe preset fill is resolved",
      "bounds": { "x": 96, "y": 188, "w": 288, "h": 520 },
      "padding": { "top": 0, "right": 0, "bottom": 0, "left": 0 },
      "max_items": 1,
      "max_lines": 0,
      "fallback_rule": "render scenario_image as the true content layer; fallback to safe preset image only if scenario_image is absent; background_base_layer must not substitute for this layer",
      "collapse_rule": "never collapse into background substitution; render safe preset when scenario_image is absent"
    },
    "product_card_shell_layer": {
      "visible_when": "always",
      "bounds": { "x": 456, "y": 188, "w": 300, "h": 520 },
      "padding": { "top": 22, "right": 20, "bottom": 22, "left": 20 },
      "max_items": 1,
      "max_lines": 0,
      "fallback_rule": "keep product card shell visible while product_image_layer resolves inside it",
      "collapse_rule": "never collapse"
    },
    "product_image_layer": {
      "visible_when": "product_image.url exists",
      "bounds": { "x": 456, "y": 188, "w": 300, "h": 520 },
      "padding": { "top": 22, "right": 20, "bottom": 22, "left": 20 },
      "max_items": 1,
      "max_lines": 0,
      "fallback_rule": "contain product image inside product card shell only",
      "collapse_rule": "collapse when product_image.url is absent"
    },
    "feature_callout_layer": {
      "visible_when": "features.length > 0",
      "bounds": { "x": 764, "y": 204, "w": 164, "h": 392 },
      "padding": { "top": 0, "right": 0, "bottom": 0, "left": 0 },
      "max_items": 4,
      "max_lines": 2,
      "fallback_rule": "render up to 4 fixed callout boxes without overlapping product card content area",
      "collapse_rule": "collapse when features.length == 0"
    },
    "title_layer": {
      "visible_when": "title present",
      "bounds": { "x": 112, "y": 744, "w": 800, "h": 84 },
      "padding": { "top": 0, "right": 20, "bottom": 0, "left": 20 },
      "max_items": 1,
      "max_lines": 2,
      "fallback_rule": "auto-shrink inside dedicated safe text zone above bottom gallery",
      "collapse_rule": "collapse when title is empty"
    },
    "subtitle_layer": {
      "visible_when": "subtitle present",
      "bounds": { "x": 152, "y": 840, "w": 720, "h": 28 },
      "padding": { "top": 4, "right": 14, "bottom": 0, "left": 14 },
      "max_items": 1,
      "max_lines": 1,
      "fallback_rule": "truncate inside dedicated subtitle lane below title_layer",
      "collapse_rule": "collapse when subtitle is empty"
    },
    "bottom_gallery_shell_layer": {
      "visible_when": "gallery state is show or fallback-fill",
      "bounds": { "x": 96, "y": 888, "w": 832, "h": 72 },
      "padding": { "top": 8, "right": 0, "bottom": 8, "left": 0 },
      "max_items": 4,
      "max_lines": 0,
      "fallback_rule": "keep shell for filled gallery states",
      "collapse_rule": "collapse when gallery state is hidden"
    },
    "bottom_gallery_items_layer": {
      "visible_when": "gallery_images.length > 0",
      "bounds": { "x": 96, "y": 904, "w": 832, "h": 56 },
      "padding": { "top": 0, "right": 0, "bottom": 0, "left": 0 },
      "max_items": 4,
      "max_lines": 0,
      "fallback_rule": "cycle available gallery_images deterministically to fill up to 4 slots; if none, do not render ghost placeholders",
      "collapse_rule": "collapse this items layer when gallery_images.length == 0; allow shell to hide or collapse with it"
    },
    "bottom_tagline_layer": {
      "visible_when": "operator tagline binding exists",
      "bounds": { "x": 196, "y": 966, "w": 632, "h": 20 },
      "padding": { "top": 0, "right": 12, "bottom": 0, "left": 12 },
      "max_items": 1,
      "max_lines": 1,
      "fallback_rule": "hide entirely when no explicit operator tagline binding is supplied",
      "collapse_rule": "collapse when operator tagline binding is absent"
    }
  },
  "slot_contracts": {
    "background_base_layer": {
      "slot_id": "background_base_layer",
      "region_id": "background_region",
      "bounds": [0, 0, 1024, 1024],
      "visible_when": "always",
      "source_binding": "background_result.url",
      "fallback_rule": "background_only_atmosphere",
      "collapse_rule": "never_collapse"
    },
    "background_tone_layer": {
      "slot_id": "background_tone_layer",
      "region_id": "background_region",
      "bounds": [0, 0, 1024, 1024],
      "visible_when": "explicit_tone_overlay_bound",
      "source_binding": "background_tone_overlay",
      "fallback_rule": "disabled_by_default",
      "collapse_rule": "collapse_if_unbound"
    },
    "header_shell_layer": {
      "slot_id": "header_shell_layer",
      "region_id": "header_region",
      "bounds": [72, 56, 880, 104],
      "visible_when": "always",
      "source_binding": "template_dual_v2.header_shell",
      "fallback_rule": "keep_shell_visible",
      "collapse_rule": "never_collapse"
    },
    "brand_logo_slot": {
      "slot_id": "brand_logo_slot",
      "region_id": "header_region",
      "bounds": [104, 74, 120, 64],
      "visible_when": "logo.url exists",
      "source_binding": "logo.url",
      "fallback_rule": "hide_logo_shift_brand_text_left",
      "collapse_rule": "collapse_when_logo_absent"
    },
    "brand_text_slot": {
      "slot_id": "brand_text_slot",
      "region_id": "header_region",
      "bounds": [244, 72, 432, 68],
      "visible_when": "brand_name exists",
      "source_binding": "brand_name",
      "fallback_rule": "expand_when_logo_collapses",
      "collapse_rule": "collapse_when_brand_name_empty"
    },
    "agent_pill_slot": {
      "slot_id": "agent_pill_slot",
      "region_id": "header_region",
      "bounds": [756, 78, 156, 48],
      "visible_when": "agent_name exists",
      "source_binding": "agent_name",
      "fallback_rule": "truncate_to_fixed_width",
      "collapse_rule": "collapse_when_agent_name_empty"
    },
    "scenario_card_shell_slot": {
      "slot_id": "scenario_card_shell_slot",
      "region_id": "scenario_region",
      "bounds": [96, 188, 288, 520],
      "visible_when": "always",
      "source_binding": "template_dual_v2.scenario_shell",
      "fallback_rule": "keep_shell_show_missing_in_metadata",
      "collapse_rule": "never_collapse"
    },
    "scenario_image_slot": {
      "slot_id": "scenario_image_slot",
      "region_id": "scenario_region",
      "bounds": [96, 188, 288, 520],
      "visible_when": "scenario_image.url exists",
      "source_binding": "scenario_image.url",
      "fallback_rule": "safe_preset_fill_if_absent",
      "collapse_rule": "keep_shell_show_missing_in_metadata"
    },
    "product_card_shell_slot": {
      "slot_id": "product_card_shell_slot",
      "region_id": "product_region",
      "bounds": [456, 188, 300, 520],
      "visible_when": "always",
      "source_binding": "template_dual_v2.product_shell",
      "fallback_rule": "keep_shell_visible",
      "collapse_rule": "never_collapse"
    },
    "product_image_slot": {
      "slot_id": "product_image_slot",
      "region_id": "product_region",
      "bounds": [456, 188, 300, 520],
      "visible_when": "product_image.url exists",
      "source_binding": "product_image.url",
      "fallback_rule": "hide_product_image_keep_shell",
      "collapse_rule": "keep_shell_show_missing_in_metadata"
    },
    "feature_callout_slots": {
      "slot_id": "feature_callout_slots",
      "region_id": "feature_region",
      "bounds": [764, 204, 164, 392],
      "visible_when": "features.length > 0",
      "source_binding": "features[]",
      "fallback_rule": "render_up_to_4_fixed_boxes",
      "collapse_rule": "collapse_when_features_empty"
    },
    "title_box": {
      "slot_id": "title_box",
      "region_id": "bottom_region",
      "bounds": [112, 744, 800, 84],
      "visible_when": "title exists",
      "source_binding": "title",
      "fallback_rule": "auto_shrink_keep_safe_margins",
      "collapse_rule": "collapse_when_title_empty"
    },
    "subtitle_box": {
      "slot_id": "subtitle_box",
      "region_id": "bottom_region",
      "bounds": [152, 840, 720, 28],
      "visible_when": "subtitle exists",
      "source_binding": "subtitle",
      "fallback_rule": "truncate_keep_safe_margins",
      "collapse_rule": "collapse_when_subtitle_empty"
    },
    "gallery_shell_slot": {
      "slot_id": "gallery_shell_slot",
      "region_id": "bottom_region",
      "bounds": [96, 888, 832, 72],
      "visible_when": "gallery_images.length > 0 or fallback_fill_enabled",
      "source_binding": "gallery_images[]",
      "fallback_rule": "show_or_fallback_fill_or_hide",
      "collapse_rule": "collapse_when_gallery_hidden"
    },
    "gallery_item_slots": {
      "slot_id": "gallery_item_slots",
      "region_id": "bottom_region",
      "bounds": [96, 904, 832, 56],
      "visible_when": "gallery_images.length > 0",
      "source_binding": "gallery_images[]",
      "fallback_rule": "deterministic_cycle_fill_up_to_4_items",
      "collapse_rule": "hide_full_gallery_strip_when_empty"
    },
    "tagline_box": {
      "slot_id": "tagline_box",
      "region_id": "bottom_region",
      "bounds": [196, 966, 632, 20],
      "visible_when": "operator_tagline exists",
      "source_binding": "operator_tagline",
      "fallback_rule": "hide_if_unbound",
      "collapse_rule": "collapse_when_unbound"
    }
  },
  "protected_zones": [
    { "name": "header_banner", "x": 72, "y": 56, "w": 880, "h": 104 },
    { "name": "scenario_card", "x": 96, "y": 188, "w": 288, "h": 520 },
    { "name": "product_card", "x": 456, "y": 188, "w": 300, "h": 520 },
    { "name": "feature_column", "x": 764, "y": 204, "w": 164, "h": 392 },
    { "name": "text_zone", "x": 112, "y": 728, "w": 800, "h": 144 },
    { "name": "gallery_band", "x": 96, "y": 888, "w": 832, "h": 72 }
  ],
  "slots": {
    "logo": { "x": 104, "y": 74, "w": 120, "h": 64, "fit": "contain" },
    "brand_name": { "x": 244, "y": 72, "w": 432, "h": 68 },
    "agent_name": { "x": 756, "y": 78, "w": 156, "h": 48 },
    "scenario": { "x": 96, "y": 188, "w": 288, "h": 520, "fit": "cover", "radius": 24 },
    "product": { "x": 456, "y": 188, "w": 300, "h": 520, "fit": "contain", "radius": 24 },
    "gallery": [
      { "x": 96, "y": 904, "w": 196, "h": 56, "fit": "cover", "radius": 14 },
      { "x": 308, "y": 904, "w": 196, "h": 56, "fit": "cover", "radius": 14 },
      { "x": 520, "y": 904, "w": 196, "h": 56, "fit": "cover", "radius": 14 },
      { "x": 732, "y": 904, "w": 196, "h": 56, "fit": "cover", "radius": 14 }
    ],
    "title": { "x": 112, "y": 744, "w": 800, "h": 84 },
    "subtitle": { "x": 152, "y": 840, "w": 720, "h": 28 },
    "bottom_tagline": { "x": 196, "y": 966, "w": 632, "h": 20 }
  }
}
